{
  "name": "stakehumansignal",
  "version": "1.0.0",
  "description": "Staked human feedback marketplace — ERC-8183 + ERC-8004 on Base",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "deploy:sepolia": "hardhat run scripts/deploy-sepolia.js --network base-sepolia",
    "test:frontend": "cd frontend && bun run test",
    "test:all": "npx hardhat test && python -m pytest test/ -v && cd frontend && bun run test"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "viem": "^2.47.5"
  },
  "devDependencies": {
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0"
  }
}
