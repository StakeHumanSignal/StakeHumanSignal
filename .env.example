# ============================================
# StakeHumanSignal — Environment Variables
# ============================================
# Copy to .env and fill in your values.
# NEVER commit .env — it's in .gitignore.

# === WALLET (required for on-chain operations) ===
PRIVATE_KEY=
BASE_SEPOLIA_PRIVATE_KEY=

# === NETWORKS ===
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://sepolia.base.org
ETH_RPC_URL=https://ethereum-rpc.publicnode.com

# === x402 PAYMENT VERIFICATION (Coinbase CDP) ===
# Get keys from: https://portal.cdp.coinbase.com
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
RECEIVER_ADDRESS=

# === FILECOIN ONCHAIN CLOUD ===
# Synapse SDK uses the same PRIVATE_KEY for Filecoin calibration.
# USDFC obtained via CDP on https://stg.usdfc.net (see agent/skills/filecoin.skill.md)
FILECOIN_NETWORK=calibration
FILECOIN_BRIDGE_URL=http://localhost:3001

# === LIGHTHOUSE (secondary storage — fast IPFS + Filecoin deals) ===
# Get key from: https://files.lighthouse.storage
LIGHTHOUSE_API_KEY=

# === LIDO MCP ===
# Benchmark APY for vault health alerts (default: Lido historical ~3.5%)
LIDO_BENCHMARK_APY=3.5
LIDO_NETWORK=mainnet

# === OLAS MECH-CLIENT (Hire an Agent track) ===
# Find mech address at: https://build.olas.network/hire
OLAS_MECH_ADDRESS=

# === OPENSERV (Ship Something Real track) ===
# Register at: https://platform.openserv.ai
OPENSERV_API_KEY=

# === API ===
API_BASE_URL=http://localhost:8000

# === BASESCAN (contract verification) ===
BASESCAN_API_KEY=

# === SYNTHESIS HACKATHON ===
SYNTHESIS_API_KEY=
MOLTBOOK_API_KEY=

